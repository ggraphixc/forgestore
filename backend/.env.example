# ============================================================
# ForgeStore — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# --- Database ---
# SQLite (development): sqlite:///./forgestore.db
# PostgreSQL (production -- Railway provides this automatically):
#     DATABASE_URL=postgresql://user:password@host:5432/forgestore
# Production example:
# DATABASE_URL=postgresql://user:password@host:5432/defaultdb?sslmode=require
DATABASE_URL=sqlite:///./forgestore.db

# --- Security ---
# Generate a strong random key: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-this-to-a-very-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Site ---
# Production example: SITE_BASE_URL=https://your-project.up.railway.app
SITE_BASE_URL=http://127.0.0.1:8000
SITE_NAME=ForgeStore

# --- Transactional Emails ---
# Recommended: Use Brevo API (no IP authorization issues on cloud platforms like Render/Railway)
# Get API v3 key from: Brevo Dashboard → Settings → SMTP & API → API Keys
# BREVO_API_KEY=your-api-v3-key-here

# Fallback SMTP (used if BREVO_API_KEY is not set)
# Recommended provider: Brevo (free tier -- 300 emails/day)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
# SMTP_USER=your-brevo-login@smtp-brevo.com
# SMTP_PASSWORD=your-brevo-smtp-key
# FROM_EMAIL=noreply@forgestore.com

# --- Paystack (Payment Gateway) ---
# Get your keys from https://dashboard.paystack.com/#/settings/keys
# PAYSTACK_SECRET_KEY=sk_test_xxxx
# PAYSTACK_PUBLIC_KEY=pk_test_xxxx

# --- Flutterwave (Alternative Payment Gateway) ---
# Get your keys from https://dashboard.flutterwave.com/dashboard/settings/keys
# FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxx
# FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxx
# FLUTTERWAVE_ENCRYPTION_KEY=FLWSECK_TESTxxxx

# --- Google OAuth ---
# Get credentials from https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Default Payment Provider ---
# Which payment gateway to use by default: "paystack" or "flutterwave"
# DEFAULT_PAYMENT_PROVIDER=paystack

# --- Debug Mode ---
# Set to "true" for detailed error logging in development
# DEBUG=false

# --- CORS ---
# Comma-separated frontend URLs allowed for cross-origin requests.
# Production: https://app.yourdomain.com,https://www.yourdomain.com
# Production example:
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-project.up.railway.app
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Railway Deployment (set in Railway dashboard, not in .env) ---
# PORT=8080            (set automatically by Railway)
# WEB_CONCURRENCY=4    (gunicorn worker count)
# GUNICORN_LOG_LEVEL=info
